<?xml version="1.0" encoding="utf-8"?>
<!--
  Repo-pinned NuGet sources. `<clear/>` drops any inherited machine/user sources
  (e.g. a private, auth-required feed) so restore is reproducible on any machine
  and in CI. Every package this solution needs is public on nuget.org.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <packageSourceMapping>
    <clear />
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
