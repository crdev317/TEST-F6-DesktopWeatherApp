  classDef input fill:#ede9fe,stroke:#7c3aed,color:#4c1d95;
  classDef output fill:#dcfce7,stroke:#16a34a,color:#14532d;
  classDef state fill:#dbeafe,stroke:#2563eb,color:#1e3a8a;
  classDef gate fill:#ffffff,stroke:#dc2626,color:#7f1d1d;
  classDef human fill:#fef3c7,stroke:#d97706,color:#7c2d12;
  classDef start fill:#fecaca,stroke:#dc2626,color:#7f1d1d;
  classDef fail fill:#fee2e2,stroke:#dc2626,color:#7f1d1d;
  classDef terminal fill:#bbf7d0,stroke:#16a34a,color:#14532d;
